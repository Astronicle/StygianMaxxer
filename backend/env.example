# ── stygianMaxxer backend — environment variables ─────────────────────────────
# Copy this file to .env and fill in real values.
# .env is already in .gitignore — never commit it.

# Database
DB_URL=jdbc:postgresql://localhost:5432/stygianMaxxer_db
DB_USERNAME=admin
DB_PASSWORD=change_me

# JWT
# Generate a secure secret: openssl rand -base64 48
JWT_SECRET=change_me_to_a_long_random_secret_32_plus_chars
JWT_EXPIRATION_SECONDS=86400

# Spring profile (local | prod)
SPRING_PROFILES_ACTIVE=local
